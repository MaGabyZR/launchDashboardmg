# Launch Tracker Dashboard - Environment Variables
# Copy this file to .env and fill in your actual values

# ===========================================
# DATABASE CONFIGURATION (Required)
# ===========================================
# Vercel Postgres connection string
# Get this from your Vercel project dashboard under Storage > Postgres
# Format: postgres://user:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/launch_tracker_dev"

# ===========================================
# ENVIRONMENT
# ===========================================
NODE_ENV="development"

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
# Backend API base URL
# Local: http://localhost:3000
# Production: automatically set by Vercel
VITE_API_BASE_URL="http://localhost:3000"

# ===========================================
# SCRAPING SERVICE CONFIGURATION (Optional)
# ===========================================
# Rate limiting for web scraping
SCRAPER_MAX_REQUESTS_PER_MINUTE=10
SCRAPER_TIMEOUT_MS=10000
SCRAPER_MAX_RETRIES=3

# ===========================================
# YC API CONFIGURATION (Optional)
# ===========================================
YC_API_BASE_URL="https://api.ycombinator.com/v0.1"
YC_API_CACHE_TTL_HOURS=24
